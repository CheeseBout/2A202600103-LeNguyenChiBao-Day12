# Copy thanh .env va dien gia tri that
# Khong commit file .env len Git

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=false

# App
APP_NAME=AI Agent
APP_VERSION=1.0.0

# LLM
OPENAI_API_KEY=
LLM_MODEL=mock-llm

# Security — BẮT BUỘC thay trong production
AGENT_API_KEY=replace-with-strong-secret

# Rate & Budget
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_WINDOW_SECONDS=60
MONTHLY_BUDGET_USD=10.0
GLOBAL_MONTHLY_BUDGET_USD=500.0

# Storage
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=*
